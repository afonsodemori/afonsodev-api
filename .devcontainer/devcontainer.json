{
  "name": "afonsodev-api",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/app",

  "mounts": [
    "source=cloudflared,target=/home/vscode/.cloudflared,type=volume",
    "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached"
  ],

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/go:1": { "version": "1.25.6" },
    "ghcr.io/devcontainers/features/node:1": { "version": "24" },
    "ghcr.io/devcontainers-extra/features/cloudflared:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "mkhl.shfmt"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/install.sh"
}
